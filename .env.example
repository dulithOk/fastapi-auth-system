# Application Settings
APP_NAME="FastAPI Auth System"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql+asyncpg://dulith:rootPassword@db:5432/authdb
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@db:5432/authdb

# JWT Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-use-256-bit
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# First Admin User (auto-created on startup)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=Admin@123456
FIRST_ADMIN_USERNAME=admin
